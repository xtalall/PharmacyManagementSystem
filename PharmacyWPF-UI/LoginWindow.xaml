<Window x:Class="PharmacyWPF_UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="PharmaCare - Sign In"
        Height="640"
        Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E8F4F3"
        FontFamily="Alexandria">
    <Grid>
        <Border Background="White"
                CornerRadius="16"
                BorderBrush="#c4d9d6"
                BorderThickness="1"
                Padding="40,36"
                MaxWidth="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <iconPacks:PackIconMaterial Kind="Pill"
                                                Width="32"
                                                Height="32"
                                                Foreground="#00acb2"
                                                VerticalAlignment="Center"/>
                    <TextBlock Text="PharmaCare"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#3b413c"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Pharmacy Management System"
                           FontSize="13"
                           Foreground="#8a9996"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <TextBlock Text="Username"
                           FontSize="12" Foreground="#8a9996" Margin="0,0,0,4"
                           FontFamily="Alexandria"/>
                <TextBox x:Name="UsernameBox"
                         Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center"
                         FontFamily="Alexandria"
                         Margin="0,0,0,16"
                         KeyDown="Input_KeyDown"/>

                <TextBlock Text="Password"
                           FontSize="12" Foreground="#8a9996" Margin="0,0,0,4"
                           FontFamily="Alexandria"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="38"
                             FontFamily="Alexandria"
                             FontSize="13"
                             Padding="10,0"
                             Margin="0,0,0,8"
                             KeyDown="Input_KeyDown"/>

                <TextBlock x:Name="ErrorText"
                           Text=""
                           Foreground="#DC2626"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <Button x:Name="LoginBtn"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="44"
                        FontFamily="Alexandria"
                        FontSize="15"
                        Content="Sign In"
                        Click="LoginBtn_Click"
                        Margin="0,4,0,20"/>

                <Border Background="#F5F9F8"
                        CornerRadius="10"
                        Padding="14"
                        BorderBrush="#c4d9d6"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Demo accounts"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="#3b413c"
                                   Margin="0,0,0,8"/>
                        <TextBlock FontSize="11"
                                   Foreground="#8a9996"
                                   TextWrapping="Wrap"
                                   LineHeight="18">
                            <Run Text="admin / admin123"/>
                            <LineBreak/>
                            <Run Text="pharmacist / pharma123"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
