<Page x:Class="PharmacyWPF_UI.Pages.Pharmacist.ModifyMedicinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="Modify Medicine"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Modify Medicine"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Search, edit, or remove medicines from inventory"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,20"/>

            <Grid Margin="0,0,0,16">
                <TextBox x:Name="SearchBox"
                         Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center"
                         FontFamily="Alexandria"
                         TextChanged="SearchBox_TextChanged"/>
                <iconPacks:PackIconMaterial Kind="Magnify"
                                            Width="16" Height="16"
                                            Foreground="#8a9996"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0"
                                            IsHitTestVisible="False"/>
                <TextBlock Text="Search by name or ID..."
                           IsHitTestVisible="False"
                           FontFamily="Alexandria"
                           FontSize="13"
                           Foreground="#8a9996"
                           Margin="36,0,0,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                        <Condition Binding="{Binding IsFocused, ElementName=SearchBox}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Border x:Name="EditPanel"
                    Visibility="Collapsed"
                    Background="White"
                    BorderBrush="#00acb2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Stock" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="EditStockBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Unit Price ($)" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="EditPriceBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Expiry Date" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <DatePicker x:Name="EditExpiryPicker" Height="38" FontSize="13" Background="#F9FAFB" BorderBrush="#c4d9d6" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal">
                        <Button Content="Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38"
                                Padding="16,0"
                                Margin="0,0,8,0"
                                Click="SaveEdit_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="38"
                                Padding="16,0"
                                Click="CancelEdit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <DataGrid x:Name="MedicineGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource ModernDataGridRowStyle}"
                          MinHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="90" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="2*" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="80" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="PRICE" Binding="{Binding PriceDisplay}" Width="90" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="EXPIRY" Binding="{Binding ExpiryDisplay}" Width="110" FontFamily="Alexandria"/>
                        <DataGridTemplateColumn Header="ACTIONS" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource OutlineEditButtonStyle}"
                                                Margin="0,0,8,0"
                                                Tag="{Binding}"
                                                Click="EditRow_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="PencilOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Edit" FontFamily="Alexandria" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource OutlineDangerButtonStyle}"
                                                Tag="{Binding}"
                                                Click="DeleteRow_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Delete" FontFamily="Alexandria" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
