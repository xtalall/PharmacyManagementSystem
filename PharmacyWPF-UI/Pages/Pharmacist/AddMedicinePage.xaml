<Page x:Class="PharmacyWPF_UI.Pages.Pharmacist.AddMedicinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="Add Medicine"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Add Medicine"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Register a new medicine in the inventory"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,20"/>

            <Border Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Medicine Name" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="NameBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Manufacturer" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="ManufacturerBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="Unit Price ($)" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="PriceBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="Stock Quantity" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="StockBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,0,16">
                        <TextBlock Text="Medicine ID" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="IdBox" Height="36" Padding="10,0" FontSize="13" Background="#E6F7F8" Foreground="#085041" BorderBrush="#9db5b2" BorderThickness="1" IsReadOnly="True" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="2" Margin="0,0,0,16">
                        <TextBlock Text="Category" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <ComboBox x:Name="CategoryCombo"
                                  Height="38" FontSize="13" Background="#E6F7F8" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center"
                                  FontFamily="Alexandria"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,0,16">
                        <TextBlock Text="Production Date" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <DatePicker x:Name="ProductionDatePicker" Height="38" FontSize="13" Background="#F9FAFB" BorderBrush="#c4d9d6" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="3" Margin="0,0,0,16">
                        <TextBlock Text="Expiry Date" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <DatePicker x:Name="ExpiryDatePicker" Height="38" FontSize="13" Background="#F9FAFB" BorderBrush="#c4d9d6" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4">
                        <TextBlock Text="Notes" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="NotesBox"
                                 FontFamily="Alexandria"
                                 Height="88"
                                 Padding="10,8"
                                 FontSize="13"
                                 Background="#F9FAFB"
                                 Foreground="#3b413c"
                                 BorderBrush="#c4d9d6"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Height="42"
                        Padding="24,0"
                        Margin="0,0,12,0"
                        Click="AddBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Medicine" FontFamily="Alexandria" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButtonStyle}"
                        Height="42"
                        Padding="20,0"
                        Click="ClearBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear" FontFamily="Alexandria" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
