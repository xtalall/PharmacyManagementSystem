<Page x:Class="PharmacyWPF_UI.Pages.Pharmacist.ValidityCheckPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:PharmacyWPF_UI.Controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="Validity Check"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="Validity Check"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Monitor medicine expiry status and take action"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,20"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:StatCardControl Grid.Column="0"
                                          x:Name="ValidCard"
                                          Title="Valid Medicines"
                                          ShowTrend="False"
                                          IconKind="CheckCircleOutline"/>
                <controls:StatCardControl Grid.Column="1"
                                          x:Name="ExpiringCard"
                                          Title="Expiring &lt; 30 Days"
                                          ShowTrend="False"
                                          IconKind="AlertOutline"/>
                <controls:StatCardControl Grid.Column="2"
                                          Margin="0,0,0,0"
                                          x:Name="ExpiredCard"
                                          Title="Expired"
                                          ShowTrend="False"
                                          IconKind="CloseCircleOutline"/>
            </Grid>

            <Border Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Flagged Medicines"
                               FontFamily="Alexandria"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#3b413c"
                               Margin="0,0,0,16"/>

                    <DataGrid x:Name="FlaggedGrid"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              MinHeight="360">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="90" FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="2*" FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="STOCK" Binding="{Binding Stock}" Width="80" FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="EXPIRY" Binding="{Binding ExpiryDisplay}" Width="110" FontFamily="Alexandria"/>
                            <DataGridTemplateColumn Header="STATUS" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <controls:StatusBadgeControl Status="{Binding Status}" Margin="0,4"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ACTION" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource OutlineDangerButtonStyle}"
                                                    Margin="0,0,8,0"
                                                    Tag="{Binding}"
                                                    Click="RemoveBtn_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Remove" FontFamily="Alexandria" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource OutlineNeutralButtonStyle}"
                                                    Tag="{Binding}"
                                                    Click="FlagBtn_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="FlagOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Flag" FontFamily="Alexandria" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
