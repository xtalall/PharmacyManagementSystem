<Page x:Class="PharmacyWPF_UI.Pages.Pharmacist.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:PharmacyWPF_UI.Controls"
      mc:Ignorable="d"
      Title="Dashboard"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- Page header -->
            <TextBlock Text="Dashboard"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Pharmacy Data Overview"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,0"/>

            <!-- Stat cards -->
            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:StatCardControl Grid.Column="0"
                                          Title="Medicines in stock"
                                          Value="24"
                                          IconKind="PackageVariant"/>

                <controls:StatCardControl Grid.Column="1"
                                          Title="Expired Medicines"
                                          Value="4"
                                          ShowTrend="True"
                                          TrendText="must be removed."
                                          TrendIsPositive="False"
                                          IconKind="AlertOutline" />

                <controls:StatCardControl Grid.Column="0"
                                          Grid.Row="1"
                                          Margin="0,4,0,0"
                                          Title="Expiring soon"
                                          Value="10"
                                          ShowTrend="True"
                                          TrendText="Expires within 30 days"
                                          TrendIsPositive="True"
                                          IconKind="CalendarAlertOutline"/>

                <controls:StatCardControl Grid.Column="1"
                                          Grid.Row="1"
                                          Margin="0,4,0,0"
                                          Title="Low stock"
                                          Value="10"
                                          ShowTrend="True"
                                          TrendText="A new order is required"
                                          TrendIsPositive="False"
                                          IconKind="PackageDown"/>
            </Grid>

            <!-- Expiring medicines table -->
            <Border Margin="0,24,0,0"
                    Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="Medicines Expiring Within 30 Days"
                               FontFamily="Alexandria"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#3b413c"
                               Margin="0,0,0,16"/>

                    <DataGrid x:Name="ExpiringGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              MinHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME"
                                                Binding="{Binding Name}"
                                                Width="2*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="STOCK"
                                                Binding="{Binding Stock}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="EXPIRY DATE"
                                                Binding="{Binding ExpiryDate, StringFormat='yyyy-MM-dd'}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTemplateColumn Header="STATUS" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <controls:StatusBadgeControl Status="{Binding Status}" Margin="0,4"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
