<Page x:Class="PharmacyWPF_UI.Pages.Admin.PharmacistsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="Pharmacists"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Pharmacists"
                               FontFamily="Alexandria"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#3b413c"/>
                    <TextBlock Text="Manage pharmacy staff members"
                               FontFamily="Alexandria"
                               FontSize="14"
                               Foreground="#8a9996"
                               Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Padding="18,0"
                        VerticalAlignment="Center"
                        Click="AddStaffBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Staff" FontFamily="Alexandria" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border x:Name="AddStaffPanel"
                    Visibility="Collapsed"
                    Background="White"
                    BorderBrush="#00acb2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Full Name" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="StaffNameBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Phone" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="StaffPhoneBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Shift" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <ComboBox x:Name="StaffShiftCombo" Height="38" FontSize="13" Background="#E6F7F8" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal">
                        <Button Content="Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                Click="SaveStaff_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="38"
                                Padding="14,0"
                                Click="CancelStaff_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <DataGrid x:Name="StaffGrid"
                          AutoGenerateColumns="False"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource ModernDataGridRowStyle}"
                          MinHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="2*" FontFamily="Alexandria"/>
                        <DataGridTemplateColumn Header="ROLE" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdminRole}" Value="True">
                                                        <Setter Property="Background" Value="#EDE9FE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Role}" FontFamily="Alexandria" FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="*" FontFamily="Alexandria"/>
                        <DataGridTextColumn Header="SHIFT" Binding="{Binding Shift}" Width="100" FontFamily="Alexandria"/>
                        <DataGridTemplateColumn Header="STATUS" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontFamily="Alexandria" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTIONS" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OutlineDangerButtonStyle}"
                                            Tag="{Binding}"
                                            Click="DeleteStaff_Click"
                                            Content="Remove"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
