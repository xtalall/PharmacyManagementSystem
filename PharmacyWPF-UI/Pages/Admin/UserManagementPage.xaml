<Page x:Class="PharmacyWPF_UI.Pages.Admin.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="User Management"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="User Management"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Create and manage user accounts"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Create user -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#c4d9d6"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Create New User"
                                   FontFamily="Alexandria"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#3b413c"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Full Name" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="FullNameBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria" Margin="0,0,0,12"/>

                        <TextBlock Text="Username" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <TextBox x:Name="UsernameBox" Height="36" Padding="10,0" FontSize="13" Background="#F9FAFB" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center" FontFamily="Alexandria" Margin="0,0,0,12"/>

                        <TextBlock Text="Password" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <PasswordBox x:Name="PasswordBox" Height="38" FontFamily="Alexandria" Padding="10,0" Margin="0,0,0,4"/>
                        <TextBlock Text="Leave blank when editing to keep the current password."
                                   FontFamily="Alexandria"
                                   FontSize="11"
                                   Foreground="#8a9996"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Role" FontSize="12" Foreground="#8a9996" Margin="0,0,0,4" FontFamily="Alexandria"/>
                        <ComboBox x:Name="RoleCombo"
                                  Height="38" FontSize="13" Background="#E6F7F8" Foreground="#3b413c" BorderBrush="#c4d9d6" BorderThickness="1" VerticalContentAlignment="Center"
                                  FontFamily="Alexandria"
                                  Margin="0,0,0,20"/>

                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="SaveUser_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Save User" FontFamily="Alexandria" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Height="40"
                                Click="ClearForm_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Clear" FontFamily="Alexandria" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- All accounts -->
                <Border Grid.Column="2"
                        Background="White"
                        BorderBrush="#c4d9d6"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="All Accounts"
                                   FontFamily="Alexandria"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#3b413c"
                                   Margin="0,0,0,16"/>

                        <DataGrid x:Name="UsersGrid"
                                  AutoGenerateColumns="False"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  MinHeight="420">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="*" FontFamily="Alexandria"/>
                                <DataGridTextColumn Header="NAME" Binding="{Binding FullName}" Width="*" FontFamily="Alexandria"/>
                                <DataGridTemplateColumn Header="ROLE" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                <Setter Property="Background" Value="#EDE9FE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding RoleBadgeText}" FontFamily="Alexandria" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="LAST LOGIN" Binding="{Binding LastLoginDisplay}" Width="*" FontFamily="Alexandria"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource OutlineEditButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Tag="{Binding}"
                                                        Click="EditUser_Click">
                                                    <TextBlock Text="Edit" FontFamily="Alexandria" FontSize="12"/>
                                                </Button>
                                                <Button Style="{StaticResource OutlineDangerButtonStyle}"
                                                        Tag="{Binding}"
                                                        Click="DeleteUser_Click">
                                                    <TextBlock Text="Delete" FontFamily="Alexandria" FontSize="12"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
