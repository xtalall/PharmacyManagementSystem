<Page x:Class="PharmacyWPF_UI.Pages.Admin.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:PharmacyWPF_UI.Controls"
      mc:Ignorable="d"
      Title="Admin Dashboard"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <TextBlock Text="Admin Dashboard"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="System overview and recent activity"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,0"/>


            <!-- Cards on Top-->
                <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:StatCardControl x:Name="TotalMedicineCard"
                                          Grid.Column="0"
                                          Title="Total Medicines"
                                          ShowTrend="False"
                                          IconKind="Pill"/>
                    
                <controls:StatCardControl x:Name="ExpiredMedicineCard"
                                          Grid.Column="1"
                                          Title="Expired Medicines"
                                          ShowTrend="True"
                                          TrendText="Needs Attention"
                                          TrendIsPositive="False"
                                          IconKind="CloseCircleOutline"/>
                    

                <controls:StatCardControl x:Name="todayCustomersCard"
                                          Grid.Column="2"
                                          Margin="0,0,0,0"
                                          Title="Today Customers"
                                          ShowTrend="False"
                                          IconKind="AccountCash"/>
            </Grid>

            <!-- Cards on Bottom-->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:StatCardControl x:Name="MonthTransactions"
                                          Grid.Column="0"
                                          Title="This Month Revenue"
                                          ShowTrend="False"
                                          IconKind="Cash"/>

                <controls:StatCardControl x:Name="PharmacistonDuty" 
                                          Grid.Column="1"
                                          Title="Pharmacist On Duty"
                                          ShowTrend="False"
                                          IconKind="Doctor"/>

            </Grid>

            <Border Margin="0,24,0,0"
                    Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="Recent Activity"
                               FontFamily="Alexandria"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#3b413c"
                               Margin="0,0,0,16"/>

                    <DataGrid x:Name="ActivityGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="USER"
                                                Binding="{Binding User}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTemplateColumn Header="ROLE" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="10,4"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                            <Setter Property="Background" Value="#EDE9FE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Role}"
                                                       FontFamily="Alexandria"
                                                       FontSize="12"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                <Setter Property="Foreground" Value="#6D28D9"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ACTION"
                                                Binding="{Binding Action}"
                                                Width="2*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="TIME"
                                                Binding="{Binding Time}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
