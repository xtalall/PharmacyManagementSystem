<Page x:Class="PharmacyWPF.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PharmacyWPF"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1280"
      Title="Dashboard">



    <Grid Background="#f5f1f1">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Column="0">
            <TextBlock Text="Dashboard"
                       FontSize="35"
                       FontWeight="Bold" 
                       Margin="20,20,0,20" 
                       HorizontalAlignment="Left" 
                       VerticalAlignment="Top"/>
        </Grid>
        <!--Cards Section-->
        <Grid Grid.Row="1" Margin="0,30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>




            <!-- Medicine in stock card -->
            <Border Grid.Column="0"
                    Grid.Row="0"
                    Background="White"
                    BorderBrush="green" 
                    BorderThickness="0,5,0,0" 
                    Margin="20" 
                    Padding="15"
                    CornerRadius="10">

                <Grid>
                    <TextBlock Text="Medicine In Stock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="215"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="25" 
                               FontWeight="Bold"/>
                    <TextBlock Text="In Inventory"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="Green"/>

                </Grid>

            </Border>


            <!-- Expired Medicine card -->

            <Border Grid.Column="0"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="red" 
                    BorderThickness="0,5,0,0" 
                    Margin="20" 
                    Padding="15"
                    CornerRadius="10">

                <Grid>
                    <TextBlock Text="Expired Medicine"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="13"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="25" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Needs Attention"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="red"/>

                </Grid>

            </Border>

            <!-- Total Customers card -->
            <Border Grid.Column="1"
                    Grid.Row="0"
                    Background="White"
                    BorderBrush="#2b3e35" 
                    BorderThickness="0,5,0,0" 
                    Margin="20" 
                    Padding="15"

                    CornerRadius="10">

                <Grid>
                    <TextBlock Text="Total Customers"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="26"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="25" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Customer Data"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="#2b3e35"/>

                </Grid>

            </Border>


            <!-- Total Transaction card -->
            <Border Grid.Column="1"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#66cfd0" 
                    BorderThickness="0,5,0,0" 
                    Margin="20" 
                    Padding="15"

                    CornerRadius="10">

                <Grid>
                    <TextBlock Text="Total Transaction"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="26"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="25" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Transaction History"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="#66cfd0"/>

                </Grid>

            </Border>

        </Grid>
        <!-- Transactions Table Section -->
        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="--Transaction History--"
                       FontSize="20"
                       FontWeight="Medium"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="15,15,15,0"
                       Grid.Row="0"/>
            <Border Grid.Row="1" CornerRadius="15" Padding="15" >
                <DataGrid Name="TransactionsHistory" 
              AutoGenerateColumns="False" 
              CanUserAddRows="False" 
              HeadersVisibility="Column"
              Background="White" 
              BorderThickness="0"
              GridLinesVisibility="Horizontal"
              HorizontalGridLinesBrush="Black">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Transaction ID" Width="100"/>
                        <DataGridTextColumn Header="Medicine Name" Width="*"/>
                        <DataGridTextColumn Header="Quantity" Width="80"/>
                        <DataGridTextColumn Header="Total Price" Width="100"/>
                        <DataGridTextColumn Header="Date" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>


        </Grid>
    </Grid>
</Page>
