        <Style x:Key="NavbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="BorderBrush" Value="#66e0d9"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Background="#f5f1f1" >

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--NavBar-->
        <Grid Background="#00acb2" Grid.Row="0" x:Name="NavbarGrid">



            <Grid Margin="10,10,10,10">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Button Content="Dashboard" Grid.Column="0" 
                Style="{StaticResource NavbarButtonStyle}"  
                Margin="0,0,10,0" Name="dashboard_btn" Click="dashboard_btn_Click"/>

                <Button Content="Sell Medicine" Grid.Column="1" 
                Style="{StaticResource NavbarButtonStyle}"
                Click="sellMedicineBtn_Click" 
                Margin="0,0,10,0" Name="sellMedicine_Btn"/>

                <Button Content="Medicine" Grid.Column="2"
                Style="{StaticResource NavbarButtonStyle}"
                Click="Medcine_Btn_Click" Name="Medicine_Btn"/>


                <Button Margin="0,0,10,0" Grid.Column="5" Name="usericon_btn" Width="40" Height="40" HorizontalAlignment="Right">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Fill="#f5f1f1"/>

                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>

                    <Image Source="C:\Users\Talal\Desktop\user.png"  Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>

        </Grid>

        <Grid Grid.Row="1" Grid.RowSpan="2">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
